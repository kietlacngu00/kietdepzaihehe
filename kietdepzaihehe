end

-- HÀM AUTO FARM CƠ BẢN
local function AutoFarmLoop()
    while _G.AutoFarm do
        wait(0.1)
        local player = game.Players.LocalPlayer
        if not player.Character then continue end
        
        -- Tìm quái gần nhất
        local nearestEnemy
        local shortestDistance = math.huge
        
        for _, enemy in pairs(workspace.Enemies:GetChildren()) do
            if enemy:FindFirstChild("Humanoid") and enemy.Humanoid.Health > 0 then
                local distance = (player.Character.HumanoidRootPart.Position - enemy.HumanoidRootPart.Position).Magnitude
                if distance < shortestDistance then
                    shortestDistance = distance
                    nearestEnemy = enemy
                end
            end
        end
        
        if nearestEnemy then
            -- Di chuyển đến quái
            player.Character.HumanoidRootPart.CFrame = nearestEnemy.HumanoidRootPart.CFrame * CFrame.new(0, 0, 15)
            
            -- Tấn công
            local tool = player.Character:FindFirstChildOfClass("Tool")
            if tool then
                tool:Activate()
            end
        end
    end
end

